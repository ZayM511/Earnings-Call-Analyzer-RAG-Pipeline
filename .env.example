# Copy this file to .env and fill in real values. .env is gitignored.
# The block-secrets.sh hook will refuse to commit any file matching common
# API-key patterns even if you forget.

# --- Anthropic (Claude) ---
# Get one at console.anthropic.com.
ANTHROPIC_API_KEY=

# --- Voyage AI (embeddings) ---
# Get one at voyageai.com. Free tier: 50M tokens lifetime for voyage-finance-2
# (the finance-tuned model used by this project).
VOYAGE_API_KEY=

# --- Cohere (rerank) ---
# Get one at dashboard.cohere.com.
COHERE_API_KEY=

# --- Braintrust (tracing + evals) ---
# Get one at braintrust.dev. Free tier is generous for personal projects.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=earnings-rag

# --- HuggingFace (optional) ---
# Only needed if you want to download datasets that are gated or rate-limited
# without an account. The jlh-ibm/earnings_call dataset is public, so this is
# optional during early ingestion. Get one at huggingface.co/settings/tokens.
HUGGINGFACE_TOKEN=

# --- Financial Modeling Prep (optional escalation) ---
# Only needed if HuggingFace + Motley Fool scraping leave gaps in the 56
# transcripts we need. ~$15/mo for the basic plan. financialmodelingprep.com.
FMP_API_KEY=

# --- Postgres (application connection) ---
# This is the read/write connection the application uses.
POSTGRES_URL=postgresql://earningsrag:earningsrag@localhost:5433/earningsrag

# --- Postgres (read-only role for MCP server) ---
# This is the read-only role the Postgres MCP server connects with. Created
# by the init script in docker/initdb. NEVER point the MCP server at the
# read/write role above.
POSTGRES_READONLY_URL=postgresql://earningsrag_readonly:earningsrag_readonly@localhost:5433/earningsrag

# --- GitHub (used by github and shadcn MCP servers) ---
# Fine-grained PAT with minimum scopes: contents:read, metadata:read,
# issues:read, issues:write, pull_requests:read. Scope to THIS repo only.
GITHUB_TOKEN=

# --- Guardrails (LLM10) ---
# Override the defaults from CLAUDE.md if you need to.
MAX_INPUT_TOKENS_PER_QUERY=8000
MAX_OUTPUT_TOKENS_PER_QUERY=2000
SESSION_COST_CEILING_USD=0.50
HOURLY_COST_CIRCUIT_BREAKER_USD=5.00

# --- App configuration ---
# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# Set to "true" to enable real LLM calls in tests (default false).
ENABLE_LIVE_LLM_TESTS=false
